# Copy to .env for local development. On the server, create .env with production values only.

# --- Application ---
APP_ENV=development
APP_BASE_URL=http://localhost:8000
PRODUCT_NAME=[NAME]

# --- Database (local docker-compose exposes 5433) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/arxiv

# --- Auth (development only — returns magic link in API response) ---
# In production (APP_ENV=production): must be unset or 0. Prod compose sets this to 0.
ALLOW_DEV_MAGIC_LINK_RESPONSE=1

# --- Email (required in production; local compose defaults to Mailpit) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
EMAIL_FROM=noreply@localhost
# Mailpit web UI: http://localhost:8025
# SMTP_USE_STARTTLS=0
# Production example:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_SSL=1

# --- Internal cron worker → API ---
INTERNAL_CRON_TOKEN=

# --- Debug (optional; keep off in production) ---
DEBUG_ADMIN_EMAILS=
ALLOW_DEBUG_FEATURES=0
# ALLOW_DEBUG_DIGEST_DATA_RESET=0

# --- Reverse proxy (set 1 when behind Caddy/nginx you control) ---
TRUST_PROXY_HEADERS=0

# --- Pipeline tuning ---
# Comma-separated category IDs offered in the profile picker (labels in data/arxiv_category_labels.json).
# Ingestion only fetches categories used by digest-enabled profiles, not this whole list.
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CV,cs.LG,cs.NE,cs.IR,cs.CR,cs.RO,cs.MA,cs.SI,cs.HC,cs.DB,cs.DS,cs.IT,cs.SE,cs.PL
INGESTION_MAX_RESULTS=150
EMBEDDING_LIMIT=600
DAILY_PICKS_K=3
KEYWORD_BOOST_CAP=0.25

# --- Rate limits (database-backed when APP_ENV=production) ---
RATE_LIMIT_WINDOW_SECONDS=3600
TEST_GENERATION_LIMIT_PER_USER=5
MAGIC_LINK_REQUEST_LIMIT_PER_EMAIL=3
MAGIC_LINK_REQUEST_LIMIT_PER_IP=20
MAGIC_LINK_VERIFY_LIMIT_PER_IP=30
# RATE_LIMIT_USE_DATABASE=1

# --- Worker (docker-compose) ---
CRON_INTERVAL_SECONDS=86400

# --- LLM blurbs (Phase 3) ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_BATCH_CONCURRENCY=1
LLM_BATCH_TIMEOUT_S=600
LLM_REQUEST_TIMEOUT_S=120
LLM_PROMPT_VERSION=1
LLM_ABSTRACT_MAX_CHARS=1500

# --- Production-only (docker-compose.prod.yml) ---
# POSTGRES_PASSWORD=change-me
# APP_BASE_URL=https://your-domain.com

# --- Do not set in production ---
# DISABLE_CSRF=1
# DISABLE_RATE_LIMIT=1

# --- CLI / scripts only (not used by authenticated API routes) ---
# DEFAULT_USER_ID=default
